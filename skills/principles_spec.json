        "tab_direction_must_clear_opposite_polarity": true
      },
      "fail_action": "prune_candidate",
      "severity": "error",
      "depends_on": ["P04", "P07", "P12", "P16"],
      "source_section": "원칙 25 — B+/B− 단자탭 기하학적 정의",
      "description": "B+/B− 단자탭은 해당 단자 플레이트의 기하학적 중심에서 B+/B− 출력 방향(원칙 4)으로 돌출한다.",
      "sub_checks": [
        {
          "id": "P25.1",
          "rule": "tab.width === nickel_w",
          "detail": "탭 폭 = nickel_w (원칙 7과 동일)"
        },
        {
          "id": "P25.2",
          "rule": "tab.length === tab_len",
          "detail": "탭 길이 = tab_len (설계 파라미터)"
        },
        {
          "id": "P25.3",
          "rule": "tab origin is at plate geometric_center",
          "detail": "탭은 플레이트 기하학적 중심에서 돌출"
        },
        {
          "id": "P25.4",
          "rule": "tab direction matches P04 b_plus_direction / b_minus_direction",
          "detail": "탭 방향 = 원칙 4 출력 방향"
        },
        {
          "id": "P25.5",
          "rule": "tab shape included in canonical_signature (원칙 12)",
          "detail": "탭 방향이 다르면 별개 형상"
        },
        {
          "id": "P25.6",
          "rule": "tab direction must not point toward opposite-polarity plate (P16.4)",
          "detail": "이종 극성 방향으로 탭 돌출 금지"
        }
      ],
      "test_cases": [
